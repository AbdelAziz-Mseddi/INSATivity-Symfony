# Supabase Postgres connection (Session Pooler — use this, NOT the direct connection)
# The direct connection (db.*.supabase.co) is IPv6-only and may not be reachable.
# Get these values from: Supabase Dashboard > Settings > Database > Connection Pooling
#
# Session Pooler host format: aws-0-{region}.pooler.supabase.com  (port 5432)
# Session Pooler user format: postgres.{project_ref}
DATABASE_HOST=aws-0-{region}.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres.{project_ref}
DATABASE_PASSWORD=your_db_password
SUPABASE_DB_SSLMODE=require
