{% extends 'base.html.twig' %}

{% block title %}INSATivity | Log In{% endblock %}

{% block body_class %}login-body{% endblock %}

{% block stylesheets %}
  <link rel="stylesheet" href="/styles/page.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <style>
    .main-header { display: none !important; }
    body.login-body {
        background-color: #0b090a !important;
    }
  </style>
{% endblock %}

{% block body %}
  <div class="bg-image login-bg" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -2;"></div>
  <video autoplay muted loop class="stars-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; object-fit: cover; z-index: -1; opacity: 0.6;">
    <source src="/assets/twinkling_stars_background.mp4" type="video/mp4">
  </video>
  <div class="glass-container" style="position: relative; z-index: 1;">
    <form action="#" class="login-form">
      <h1>Login</h1>

      <div id="login-message" class="login-message"></div>

      <div class="input-box">
        <input type="text" placeholder="Username" name="username" required/>
        <i class="fa-solid fa-user"></i>
      </div>

      <div class="input-box">
        <input type="password" placeholder="Password" name="password" required/>
        <i class="fa-solid fa-lock"></i>
      </div>

      <div class="remember-forgot">
        <label><input type="checkbox" name="remember"/> Remember me</label>
        <a href="#">Forgot Password?</a>
      </div>

      <button type="submit" class="btn login-submit-btn">Login</button>

      <div class="register-link">
        <p>Don't have an account? <a href="{{ path('register') }}">Register</a></p>
      </div>
    </form>
  </div>
{% endblock %}

{% block javascripts %}
  <script type="module" src="/scripts/login.js"></script>
{% endblock %}
