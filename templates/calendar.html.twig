{% extends 'base.html.twig' %}

{% block title %}INSATivity | Calendar{% endblock %}

{% block body %}
  <div class="dashboard-header">
    <h1>Event Schedule</h1>
    <div class="search-filter-wrapper">
      <input type="text" class="search-bar" placeholder="Search events, clubs, categories…" id="calSearch" />
    </div>
  </div>

  <div class="dashboard-grid">
    <!-- LEFT: Calendar -->
    <section class="calendar-section">
      <div class="calendar-header">
        <div class="calendar-title-wrapper">
          <h2 class="calendar-month">{{ currentMonth }}</h2>
          <span class="calendar-year">{{ currentYear }}</span>
        </div>
        <div class="calendar-controls">
          <button class="icon-btn" id="btnPrev" aria-label="Previous month">◀</button>
          <button class="icon-btn icon-btn-today" id="btnToday">Today</button>
          <button class="icon-btn" id="btnNext" aria-label="Next month">▶</button>
        </div>
      </div>

      <div class="calendar-grid" id="calGrid">
        <div class="day-name">Sun</div>
        <div class="day-name">Mon</div>
        <div class="day-name">Tue</div>
        <div class="day-name">Wed</div>
        <div class="day-name">Thu</div>
        <div class="day-name">Fri</div>
        <div class="day-name">Sat</div>
        {# Les jours seront remplis par JS ou par une boucle Twig si tu veux générer côté serveur #}
      </div>
    </section>

    <!-- RIGHT: Featured Events feed -->
    <aside class="feed-section">
      <h3>Upcoming Events</h3>
      <div class="feed-scroll">
        {% for event in upcomingEvents %}
          <div class="feed-item">
            <strong>{{ event.title }}</strong> – {{ event.date }}
          </div>
        {% endfor %}
      </div>
    </aside>
  </div>

  <!-- DAY DETAILS MODAL -->
  <div class="modal-overlay" id="dayPanelOverlay" role="dialog" aria-modal="true">
    <div class="modal-card day-panel-card" id="dayPanel">
      <div class="modal-header">
        <h3 class="day-panel-title">{{ selectedDay }}</h3>
        <button class="icon-btn icon-btn-close" id="btnClosePanel" aria-label="Close panel">✖</button>
      </div>
      <div class="day-panel-list">
        {% for event in dayEvents %}
          <p>{{ event.title }} – {{ event.time }}</p>
        {% endfor %}
      </div>
    </div>
  </div>
{% endblock %}
