{% extends 'base.html.twig' %}

{% block title %}INSATivity | Calendar{% endblock %}

{% block body %}
  <div class="dashboard-container">
    <div class="dashboard-header">
      <h1>Event Schedule</h1>
      <div class="search-filter-wrapper">
        <input type="text" class="search-bar" placeholder="Search events, clubs, categories…" id="calSearch" />
      </div>
    </div>

    <div class="dashboard-grid">
      <!-- LEFT: Calendar -->
      <section class="calendar-section">
        <div class="calendar-header">
          <div class="calendar-title-wrapper">
            <h2 class="calendar-month" id="calMonthLabel">—</h2>
            <span class="calendar-year" id="calYearLabel">—</span>
          </div>
          <div class="calendar-controls">
            <button class="icon-btn" id="btnPrev" aria-label="Previous month">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6" />
              </svg>
            </button>
            <button class="icon-btn icon-btn-today" id="btnToday">Today</button>
            <button class="icon-btn" id="btnNext" aria-label="Next month">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </button>
          </div>
        </div>

        <div class="calendar-grid" id="calGrid">
          <div class="day-name">Sun</div>
          <div class="day-name">Mon</div>
          <div class="day-name">Tue</div>
          <div class="day-name">Wed</div>
          <div class="day-name">Thu</div>
          <div class="day-name">Fri</div>
          <div class="day-name">Sat</div>
        </div>
      </section>

      <!-- RIGHT: Upcoming Events feed -->
      <aside class="feed-section">
        <h3>Upcoming Events</h3>
        <div class="feed-scroll" id="featuredList">
          <!-- Populated by JS -->
        </div>
      </aside>
    </div>
  </div>

  <!-- DAY DETAILS MODAL -->
  <div class="modal-overlay" id="dayPanelOverlay" role="dialog" aria-modal="true">
    <div class="modal-card day-panel-card" id="dayPanel">
      <div class="modal-header">
        <h3 class="day-panel-title" id="dayPanelTitle">—</h3>
        <button class="icon-btn icon-btn-close" id="btnClosePanel" aria-label="Close panel">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <div class="day-panel-list" id="dayPanelList"></div>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  <script type="module" src="/scripts/calendar.js?v=2"></script>
{% endblock %}
