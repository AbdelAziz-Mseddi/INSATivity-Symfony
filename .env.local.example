DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
###< Supabase Configuration ###

###> API Configuration ###
API_BASE_URL=http://localhost:8000/api
ENVIRONMENT=development
